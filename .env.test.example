# Copy to .env.test for local/CI runs (Issue #15).
# Uses a dedicated Postgres DB + Redis logical DB so tests never touch your Postman data.

NODE_ENV=test
PORT=3001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_service_test
REDIS_URL=redis://localhost:6379/1

JWT_ACCESS_SECRET=test-access-secret-change-me-32chars-min!!
JWT_REFRESH_SECRET=test-refresh-secret-change-me-32chars-min!
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

CORS_ORIGIN=http://localhost:3000

SMTP_HOST=localhost
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Auth Service Test <noreply@example.com>"

APP_URL=http://localhost:3001

# Fastest allowed by schema — keeps suite snappy
BCRYPT_SALT_ROUNDS=10

DB_POOL_MAX=5
DB_POOL_IDLE_MS=10000
DB_POOL_CONN_TIMEOUT_MS=5000

# Headroom for suite registration + a dedicated burst test for login 429
RL_LOGIN_MAX=5
RL_LOGIN_WINDOW_SEC=60
RL_FORGOT_MAX=50
RL_FORGOT_WINDOW_SEC=60
RL_REGISTER_MAX=100
RL_REGISTER_WINDOW_SEC=3600
RL_RESEND_MAX=50
RL_RESEND_WINDOW_SEC=60
