# Application
PORT=3000
NODE_ENV=development

# PostgreSQL (source of truth)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_service

# Redis (sessions, refresh tokens, rate limits)
REDIS_URL=redis://localhost:6379

# JWT secrets — use long random strings in real environments
# Generate examples: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long

# CORS — comma-separated origins, or * for local-only demos
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Access token lifetime in seconds (default 15 minutes)
JWT_ACCESS_EXPIRES_IN=900

# Refresh token lifetime in seconds (default 7 days)
JWT_REFRESH_EXPIRES_IN=604800

# SMTP / email (Mailtrap or Ethereal for local)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Auth Service <noreply@example.com>"

# Optional: bcrypt cost factor (10–12 recommended)
BCRYPT_SALT_ROUNDS=12

# PostgreSQL connection pool
DB_POOL_MAX=10
DB_POOL_IDLE_MS=30000
DB_POOL_CONN_TIMEOUT_MS=5000
